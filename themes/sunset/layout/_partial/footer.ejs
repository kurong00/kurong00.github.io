<% var v = (theme && theme.asset_version) ? theme.asset_version : ''; %>
<% var vs = v ? ('?v=' + v) : ''; %>

<% if (page && page.layout === 'tags') { %>
<script src="<%= url_for('js/tags-filter.js') %><%= vs %>"></script>
<% } %>

<% var hasLivePhoto = false; %>
<% try { %>
<%   if (page && page.content && page.content.indexOf('data-live-photo') !== -1) { %>
<%     hasLivePhoto = true; %>
<%   } %>
<% } catch (e) { %>
<%   hasLivePhoto = false; %>
<% } %>
<% if (hasLivePhoto) { %>
<script src="https://cdn.apple-livephotoskit.com/lpk/1/livephotoskit.js"></script>
<% } %>

<script>
    (function () {
        function isImageHref(href) {
            if (!href) return false;
            var clean = href.split("#")[0].split("?")[0];
            return /\.(png|jpe?g|gif|webp|bmp|svg)$/i.test(clean);
        }

        function getCaption(img) {
            if (!img) return "";
            var caption = img.getAttribute("data-caption") || img.getAttribute("title") || img.getAttribute("alt") || "";
            return (caption || "").trim();
        }

        function collectImages(container) {
            if (!container) return [];
            var nodes = container.querySelectorAll("img");
            var list = [];
            for (var i = 0; i < nodes.length; i++) {
                var img = nodes[i];
                if (!img) continue;
                if (img.closest(".livephoto-container")) continue;
                if (img.hasAttribute("data-no-lightbox")) continue;
                if (img.classList && img.classList.contains("no-lightbox")) continue;
                if (!img.currentSrc && !img.src) continue;
                list.push(img);
            }
            return list;
        }

        function resolveSrc(img) {
            if (!img) return "";
            var a = img.closest("a");
            if (a && isImageHref(a.getAttribute("href"))) return a.getAttribute("href");
            return img.currentSrc || img.src || "";
        }

        function ensureOverlay() {
            var existing = document.querySelector(".img-lightbox-overlay");
            if (existing) return existing;

            var overlay = document.createElement("div");
            overlay.className = "img-lightbox-overlay";
            overlay.setAttribute("role", "dialog");
            overlay.setAttribute("aria-modal", "true");
            overlay.style.display = "none";

            var stage = document.createElement("div");
            stage.className = "img-lightbox-stage";

            var image = document.createElement("img");
            image.className = "img-lightbox-image";
            image.alt = "";
            image.draggable = false;

            stage.appendChild(image);

            var caption = document.createElement("div");
            caption.className = "img-lightbox-caption";

            overlay.appendChild(stage);
            overlay.appendChild(caption);

            document.body.appendChild(overlay);
            return overlay;
        }

        function createController() {
            var overlay = ensureOverlay();
            var imageEl = overlay.querySelector(".img-lightbox-image");
            var captionEl = overlay.querySelector(".img-lightbox-caption");

            var state = {
                open: false,
                list: [],
                index: -1
            };

            function render() {
                var img = state.list[state.index];
                var src = resolveSrc(img);
                imageEl.src = src;
                captionEl.textContent = getCaption(img);
            }

            function openAt(list, index) {
                state.list = list || [];
                state.index = Math.max(0, Math.min(index || 0, state.list.length - 1));
                state.open = true;
                render();
                overlay.style.display = "";
                document.body.classList.add("img-lightbox-open");
            }

            function close() {
                if (!state.open) return;
                state.open = false;
                overlay.style.display = "none";
                document.body.classList.remove("img-lightbox-open");
                imageEl.removeAttribute("src");
                captionEl.textContent = "";
            }

            function prev() {
                if (!state.open || state.list.length < 2) return;
                state.index = (state.index - 1 + state.list.length) % state.list.length;
                render();
            }

            function next() {
                if (!state.open || state.list.length < 2) return;
                state.index = (state.index + 1) % state.list.length;
                render();
            }

            overlay.addEventListener("click", function (e) {
                if (!e || !e.target) return;
                if (e.target.closest && e.target.closest(".img-lightbox-image")) return;
                close();
            });
            imageEl.addEventListener("click", close);

            document.addEventListener("keydown", function (e) {
                if (!state.open) return;
                var key = e.key;
                if (key === "Escape") close();
                if (key === "ArrowLeft") prev();
                if (key === "ArrowRight") next();
            });

            return {
                openAt: openAt,
                close: close
            };
        }

        function init() {
            var container = document.querySelector(".post-container");
            if (!container) return;

            var controller = createController();
            container.addEventListener("click", function (e) {
                var img = e.target && e.target.closest ? e.target.closest("img") : null;
                if (!img) return;
                if (!container.contains(img)) return;
                if (img.closest(".livephoto-container")) return;
                if (img.hasAttribute("data-no-lightbox")) return;
                if (img.classList && img.classList.contains("no-lightbox")) return;

                var a = img.closest("a");
                if (a) {
                    var href = a.getAttribute("href") || "";
                    if (href && !isImageHref(href)) return;
                }

                var list = collectImages(container);
                if (!list.length) return;
                var index = list.indexOf(img);
                if (index < 0) index = 0;
                e.preventDefault();
                controller.openAt(list, index);
            });
        }

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", init);
        } else {
            init();
        }
    })();
</script>

<script>
    (function () {
        function isIOS() {
            var ua = navigator.userAgent || "";
            if (/iP(hone|od|ad)/.test(ua)) return true;
            if (navigator.platform === "MacIntel" && navigator.maxTouchPoints && navigator.maxTouchPoints > 1) return true;
            return false;
        }

        if (!isIOS()) return;
        if (!document.querySelector('.aplayer, .meting-tag-marker, .aplayer-tag-marker')) return;

        function tryPlayOnce() {
            var list = window.aplayers || [];
            for (var i = 0; i < list.length; i++) {
                var ap = list[i];
                try {
                    if (!ap || typeof ap.play !== "function") continue;

                    var audio = ap.audio;
                    if (audio && !audio.__aplayerAutoplayHooked) {
                        audio.__aplayerAutoplayHooked = true;
                        audio.addEventListener("play", function () {
                            cleanup();
                        }, { once: true });
                    }

                    ap.play();
                    return true;
                } catch (e) {}
            }
            return false;
        }

        var done = false;
        function cleanup() {
            if (done) return;
            done = true;
            document.removeEventListener("touchstart", handler, true);
            document.removeEventListener("touchend", handler, true);
            document.removeEventListener("click", handler, true);
        }

        function handler() {
            if (done) return;
            tryPlayOnce();
        }

        document.addEventListener("touchstart", handler, { capture: true, passive: true });
        document.addEventListener("touchend", handler, true);
        document.addEventListener("click", handler, true);
    })();
</script>

<script>
    (function () {
        var shortname = "<%= config['disqus_username'] %>";
        if (!shortname) return;

        var el = document.getElementById("disqus_thread");
        if (!el) return;

        window.disqus_shortname = shortname;
        window.disqus_identifier = el.getAttribute("data-disqus-identifier") || "<%= page && page.permalink ? page.permalink : '' %>";
        window.disqus_url = el.getAttribute("data-disqus-url") || "<%= page && page.permalink ? page.permalink : '' %>";
        if (!window.disqus_identifier) window.disqus_identifier = location.href.split("#")[0];
        if (!window.disqus_url) window.disqus_url = location.href.split("#")[0];

        if (window.DISQUS) return;
        var dsq = document.createElement("script");
        dsq.async = true;
        dsq.src = "https://" + shortname + ".disqus.com/embed.js";
        (document.head || document.body).appendChild(dsq);
    })();
</script>
