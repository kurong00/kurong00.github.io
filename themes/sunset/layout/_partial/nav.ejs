<% if (!is_post()) { %>
<nav class="navbar navbar-default navbar-custom navbar-fixed-top">
    <%
        function withRoot(p) {
            return config.root + String(p || '').replace(/^\//, '');
        }
        var menu = (config.brand && config.brand.menu) || {};
        var items = [
            { key: 'Home', fallbackHref: config.root },
            { key: 'Tags', fallbackHref: withRoot('tags/') },
            { key: 'About', fallbackHref: withRoot('about/') }
        ];
        var currentPath = (page && page.path) ? String(page.path) : '';
        function isItemActive(key) {
            if (key === 'Home') return typeof is_home === 'function' ? is_home() : currentPath === '' || currentPath === 'index.html';
            if (key === 'Tags') return (page && page.layout === 'tags') || currentPath.indexOf('tags/') === 0;
            if (key === 'About') return (page && page.layout === 'about') || currentPath.indexOf('about/') === 0;
            return false;
        }
    %>
    <div class="container-fluid nav-capsule">
        <div class="nav-capsule-menu">
          <ul class="nav navbar-nav nav-capsule-links">
              <% items.forEach(function(it){ %>
                  <% var href = menu[it.key] ? withRoot(menu[it.key]) : it.fallbackHref; %>
                  <li class="<%= isItemActive(it.key) ? 'is-active' : '' %>">
                      <a href="<%= href %>"><%= it.key %></a>
                  </li>
              <% }) %>
          </ul>
        </div>
    </div>
</nav>
<% } %>
