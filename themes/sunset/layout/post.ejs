---
layout: layout
---
<!-- Modify by Yu-Hsuan Yen -->

<!-- Post Content -->
<article>
    <div class="container">
        <div class="row">

            <!-- Post Container -->
            <div class="layout-container post-container">

                <%- page.content %>
                

                <hr>
                <!-- Pager -->
                <ul class="pager">
                    <% if (page.prev){ %>
                        <li class="previous">
                            <a href="<%- config.root %><%- page.prev.path %>" data-toggle="tooltip" data-placement="top" title="<%- page.prev.title %>">&larr; Previous Post</a>
                        </li>
                    <% } %>
                    <% if (page.next){ %>
                        <li class="next">
                            <a href="<%- config.root %><%- page.next.path %>" data-toggle="tooltip" data-placement="top" title="<%- page.next.title %>">Next Post &rarr;</a>
                        </li>
                    <% } %>
                </ul>

                <!-- disqus comment start -->
                <% if(config['disqus_username']) { %>
                    <div class="comment">
                        <div id="disqus_thread" class="disqus-thread" data-disqus-identifier="<%= page.permalink %>" data-disqus-url="<%= page.permalink %>"></div>
                    </div>
                <% } %>
                <!-- disqus comment end -->
            </div>
            
        </div>
    </div>
</article>


<% if(config['anchorjs']) { %>
<script defer src="https://cdn.staticfile.org/anchor-js/1.1.1/anchor.min.js"></script>
<script defer>
    (function () {
        if (!window.anchors) return;
        window.anchors.options = {
            visible: 'hover',
            placement: 'left',
            icon: 'ℬ'
        };
        window.anchors.add().remove('.intro-header h1').remove('.subheading').remove('.sidebar-container h5');
    })();
</script>
<style>
    /* place left on bigger screen */
    @media all and (min-width: 800px) {
        .anchorjs-link{
            position: absolute;
            left: -0.75em;
            font-size: 1.1em;
            margin-top : -0.1em;
        }
    }
</style>
<% } %>
